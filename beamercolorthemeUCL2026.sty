\mode<presentation>

\NeedsTeXFormat{LaTeX2e}

\ProvidesPackage{beamercolorthemeUCL2026}[2026/02/19 v0.1 UCL2026]

\RequirePackage{xcolor}

% All UCL colours are defined in terms of cmyk
% \selectcolormodel{cmyk}

% Define UCL colours (in addition to black and white)
%% dark colours: use white text
%% headlines: use dark purple text

%%%% Using cmyk by default, but putting in the RGB defs too just in case we need them
%%%% I didn't want to have to look them up again
%%%% We *could* also put the Pantone defs here if someone ever needs them, using xspotcolor/xespotcolor
%%%% Current URL: https://www.ucl.ac.uk/brand-and-experience/brand/visual-guidelines/colour

%% "Lead" Colours
\definecolor{darkpurple}{HTML}{361A54}
\definecolor{brightpurple}{HTML}{993BFF}
\definecolor{midpurple}{HTML}{BA82FF}

\definecolor{darkpurplergb}{RGB}{54,26,94}
\definecolor{brightpurplergb}{RGB}{153,59,255}
\definecolor{midpurplergb}{RGB}{186,130,255}

\definecolor{offwhite}{HTML}{FAFAFA} %% "For screen use only"

%% Supporting Colours

\definecolor{lightpurple}{HTML}{DDBDFF}
\definecolor{palepurple}{HTML}{EEDEFF}
\definecolor{heritageblue}{HTML}{30D6FF}


%% Chart & Graph Colours
%%%% These are defined in the PPTX presentation template
% NOTE: the PPTX HEX colours are not always the same as those on the slide
\definecolor{darkblue}{HTML}{002EA6}
\definecolor{darkorange}{HTML}{781C1C}
\definecolor{darkfuchsia}{HTML}{9E1A54}
\definecolor{darktealgreen}{HTML}{005E5C}
\definecolor{blue}{HTML}{5487FF}
\definecolor{orange}{HTML}{E36C2A}
\definecolor{fuchsia}{HTML}{ED367D}
\definecolor{tealgreen}{HTML}{00A19D}

% Primary colours
\setbeamercolor{structure}{fg=lightpurple}
\setbeamercolor{normal text}{fg=black}
\setbeamercolor{alerted text}{fg=darkorange}
\setbeamercolor{example text}{fg=darkpurple}

% Palette colours
\setbeamercolor{palette primary}{fg=white, bg=darkpurple}
\setbeamercolor{palette secondary}{fg=white, bg=darkpurple}

% Title colors
\setbeamercolor{title}{parent=palette primary}
\setbeamercolor{subtitle}{parent=palette primary}
\setbeamercolor{author}{parent=palette primary}
\setbeamercolor{date}{parent=palette primary}
\setbeamercolor{institute}{parent=palette primary}

% Frame title colours
\setbeamercolor{frametitle}{fg=darkpurple, bg=white}
\setbeamercolor{framesubtitle}{fg=darkpurple, bg=white}

% Item colours
\setbeamercolor{item}{fg=darkblue}
\setbeamercolor{subitem}{fg=darkblue}
\setbeamercolor{subsubitem}{fg=darkblue}

% Section and subsection colors
\setbeamercolor{section in toc}{fg=darkblue}
\setbeamercolor{subsection in toc}{fg=darkblue}

% Bibliography colors
\setbeamercolor{bibliography entry author}{fg=darkpurple}
\setbeamercolor{bibliography entry title}{fg=darkpurple}
\setbeamercolor{bibliography entry location}{fg=darkpurple}
\setbeamercolor{bibliography entry note}{fg=darkpurple}

% List item colours
\setbeamercolor{itemize item}{fg=darkpurple}
\setbeamercolor{itemize subitem}{fg=darkpurple}
\setbeamercolor{itemize subsubitem}{fg=darkpurple}

\setbeamercolor{enumerate item}{fg=darkpurple}
\setbeamercolor{enumerate subitem}{fg=darkpurple}
\setbeamercolor{enumerate subsubitem}{fg=darkpurple}


\mode<all>