\mode<presentation>

\NeedsTeXFormat{LaTeX2e}

\ProvidesPackage{beamerinnerthemeUCL2026}[2026/02/19 v0.1 UCL2026]

\RequirePackage{tikz}

% ================
%    Title page
% ================

\defbeamertemplate*{title page}{UCL2026}{
    \begin{tikzpicture}[remember picture, overlay]
        \fill [darkpurple] (current page.south west) rectangle (current page.north east);
        \fill [brightpurple] (current page.south west) --++ (3.76cm,0) --++ (0,\pageheight) --++ (-3.76cm,0) -- cycle;

        \draw (current page.north west) ++ (6.4cm, -1.1cm) node [below right] {\begin{minipage}{.75\pagewidth}\usebeamerfont{title}\color{white}\inserttitle\end{minipage}};
        \draw (current page.south west) ++ (6.3cm, 6.6cm) node (author node) [below right] {\usebeamerfont{author}\color{white}\insertauthor};
        \draw (current page.south west) ++ (6.3cm, 5.2cm) node [below right] {\usebeamerfont{date}\color{white}\insertdate};

        \draw (current page.south east) ++ (-9,.5) node [above right] {\includegraphics[width = 7.9cm]{logo/UCLTitleLogo.png}};

    \end{tikzpicture}
}

% ===============
%      Lists
% ===============
\setbeamertemplate{itemize item}{\tikz[baseline=-0.4ex]\draw[fill,color=.] (0,0) rectangle (0.4ex, 0.4ex);}
\setbeamertemplate{itemize subitem}{\tikz[baseline=-0.4ex]\draw[fill,color=.] (0,0) rectangle (0.3ex, 0.3ex);}
\setbeamertemplate{itemize subsubitem}{\tikz[baseline=-0.4ex]\draw[fill,color=.] (0,0) rectangle (0.3ex, 0.3ex);}

\setbeamertemplate{enumerate subitem}{\alph{enumii}.}
\setbeamertemplate{enumerate subsubitem}{\roman{enumii}.}


